# ─────────────────────────────────────────────
# varaTestAiFramework — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Application Under Test ────────────────────
BASE_URL=https://demo.playwright.dev
API_BASE_URL=https://reqres.in/api

# ── OpenAI / LLM ──────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o

# ── Vector Database ───────────────────────────
# ChromaDB (local)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=test_features

# Pinecone (cloud alternative)
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENVIRONMENT=us-east1-gcp
PINECONE_INDEX=test-features

VECTOR_DB_PROVIDER=chroma   # chroma | pinecone | memory

# ── Framework Settings ────────────────────────
FLAKINESS_THRESHOLD=0.20
MAX_SIMILAR_FEATURES=5
STEP_REUSE_TARGET=0.80
LOG_LEVEL=info

# ── Test Execution ────────────────────────────
HEADLESS=true
SLOW_MO=0
DEFAULT_TIMEOUT=30000
RETRY_ATTEMPTS=2
