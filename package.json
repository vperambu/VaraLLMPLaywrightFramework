{
  "name": "vara-test-ai-framework",
  "version": "1.0.0",
  "description": "Vara's AI-Augmented Test Automation Framework — Playwright + Cucumber with RAG Test Generation & ML Failure Prediction",
  "author": "Vara Pera",
  "type": "module",
  "scripts": {
    "test": "cucumber-js",
    "test:smoke": "cucumber-js --profile smoke",
    "test:regression": "cucumber-js --profile regression",
    "test:api": "cucumber-js --profile api",
    "test:dry": "cucumber-js --dry-run",
    "smart-gen": "node utils/ai/smart-gen/smartGen.js",
    "smart-gen:dry": "node utils/ai/smart-gen/smartGen.js --dryRun",
    "risk-report": "node utils/analytics/riskReporter.js",
    "locator-suggest": "node utils/ai/locator/locatorSuggester.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@cucumber/html-formatter": "^21.3.1",
    "@playwright/test": "^1.43.0",
    "playwright": "^1.43.0",
    "openai": "^4.47.1",
    "langchain": "^0.2.5",
    "@langchain/openai": "^0.1.3",
    "@langchain/community": "^0.2.5",
    "chromadb": "^1.8.1",
    "string-similarity": "^4.0.4",
    "uuid": "^9.0.1",
    "dotenv": "^16.4.5",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vpera/varaTestAiFramework.git"
  },
  "license": "MIT"
}
